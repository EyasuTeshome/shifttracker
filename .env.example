# ─── Auth ────────────────────────────────────────────────────────────────────
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# Bcrypt-hashed password for the single admin user.
# Generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
ADMIN_PASSWORD_HASH=$2b$12$...

# ─── GoCardless (Nordigen) Open Banking ──────────────────────────────────────
# Register free at https://bankaccountdata.gocardless.com/
GOCARDLESS_SECRET_ID=your_secret_id_here
GOCARDLESS_SECRET_KEY=your_secret_key_here

# The institution ID for Revolut in your country.
# Find via: GET https://bankaccountdata.gocardless.com/api/v2/institutions/?country=gb
GOCARDLESS_INSTITUTION_ID=REVOLUT_REVOGB21

# Full URL where GoCardless should redirect after the user authorises access.
GOCARDLESS_REDIRECT_URL=https://yourdomain.com/api/gocardless/callback

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
# Path inside the container — maps to ./data on the host via docker-compose volume
DB_PATH=/app/data/finance.db

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=https://yourdomain.com/api
